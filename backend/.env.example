DATABASE_URL=postgresql+psycopg://inventory:inventory_pass@localhost:5433/inventory_db
JWT_SECRET_KEY=replace-this-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
